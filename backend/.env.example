# ─────────────────────────────────────────────
# AgriSmart Backend — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git
# ─────────────────────────────────────────────

# MongoDB connection string (MongoDB Atlas recommended)
# Format: mongodb+srv://<user>:<password>@cluster.mongodb.net/agrismart
MONGO_URI=mongodb://localhost:27017/agrismart

# JWT secret key — use a long random string in production
JWT_SECRET=agrismart_super_secret_key_change_this_in_production

# JWT token expiry
JWT_EXPIRES_IN=7d

# Server port
PORT=5000

# Frontend URL for CORS (change to your Vercel URL in production)
CLIENT_URL=http://localhost:3000

# Environment
NODE_ENV=development

# ── Phase 4 — AI & External APIs ─────────────
# Google Gemini API Key
# Get free key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# OpenWeatherMap API Key (free tier is enough)
# Get at: https://openweathermap.org/api
WEATHER_API_KEY=your_openweather_api_key_here

# Demand surge threshold (how many buyer searches trigger alert)
DEMAND_SURGE_THRESHOLD=5
